# MongoDB connection string (required)
# Example: mongodb+srv://user:password@cluster.mongodb.net/godino-blog
MONGODB_URI=

# Blog admin token — used as Bearer token for all /api/blog/admin/* endpoints
BLOG_ADMIN_TOKEN=

# SMTP config for contact form emails
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# Pushover notifications (optional)
PUSHOVER_TOKEN=
PUSHOVER_USER=

# Site URL for CORS validation on contact form
NEXT_PUBLIC_SITE_URL=
